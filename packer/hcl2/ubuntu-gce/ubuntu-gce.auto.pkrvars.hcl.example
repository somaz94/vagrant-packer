# Copy this file to ubuntu-gce.auto.pkrvars.hcl and fill in the values.
# Variables without defaults are required.

# GCP settings (required)
account_file = "/path/to/service-account.json"
project_id   = "your-gcp-project-id"

# Provisioning password (required, sensitive)
password = "CHANGE_ME"

# Optional overrides
# machine_type        = "n1-standard-1"
# source_image_family = "ubuntu-2004-lts"
# zone                = "asia-northeast3-a"
